DATABASE_URL=postgresql://postgres:postgres@localhost:5432/blog_app_test
JWT_SECRET=test_secret_key
JWT_EXPIRES_IN=1d
NODE_ENV=test
# Suite drives the PD-collection flow (sign-up/newsletter/oauth), so the flag is
# on in tests. Routes bypass the gate under NODE_ENV=test regardless, but this
# keeps the flow enabled even if a future test opts into enabledInTest.
PD_COLLECTION_ENABLED=true
# Auto-publish flags seeded off so the getFlags snapshot test is deterministic
# (it sets every flag explicitly, but the seed path must not depend on unset env).
AUTO_PUBLISH_RELEASES_ENABLED=false
AUTO_PUBLISH_NEWS_ENABLED=false
# Dummy SMTP creds so sign-up handler's hasEmailCredentials guard passes.
# Email sending is mocked in tests (jest.mock @/src/utils/email), so values are never used.
EMAIL_USER=test@example.com
EMAIL_PASSWORD=test_password
EMAIL_SERVICE=gmail
