# Admin → bot control proxy. URL of the bot's localhost control server + the
# SAME secret configured on the bot's BOT_CONTROL_TOKEN. Separate from
# BOT_API_TOKEN (bot→blog). Unset = the /api/admin/bot/* routes return 503.
BOT_CONTROL_URL=http://127.0.0.1:8455
BOT_CONTROL_TOKEN=

# Dogs Teacher booking API (separate Postgres database on the same VDS in prod)
