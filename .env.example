DATABASE_URL=postgresql://postgres:postgres@localhost:5432/blog_app
JWT_SECRET=secret123
# Personal-data collection master switch. Unset/false = registration, OAuth
# sign-up and newsletter subscribe routes answer 404 and collect NO personal
# data (152-ФЗ default). Set to 'true' to re-enable the whole collection flow;
# the code stays in place either way. Sign-in of existing users is never gated.
#
# MUST be flipped together with the frontend NEXT_PUBLIC_PD_COLLECTION_ENABLED
# (separate deploys: this is the VDS backend, that is inlined into the Vercel
# build). Dangerous drift = backend 'true' while frontend 'false': the API then
# accepts personal data with NO consent UI in front of it. When enabling, flip
# BOTH and redeploy the frontend before/at the same time as the backend.
PD_COLLECTION_ENABLED=false
# Number of trusted reverse-proxy hops that APPEND to X-Forwarded-For (nginx's
# $proxy_add_x_forwarded_for). Used to derive the real client IP for rate-limit
# bucketing without trusting spoofable leftmost XFF entries. Default 1 (single
# nginx). Set to the actual proxy-chain depth in your deployment.
TRUSTED_PROXY_HOPS=1
# Legacy access-token lifetime — now only a fallback for the refresh lifetime.
JWT_EXPIRES_IN='3 days'
# Short-lived ACCESS token (httpOnly cookie); refreshed transparently. Default 15m.
JWT_ACCESS_EXPIRES_IN=15m
# Rotating REFRESH token lifetime (DB-backed, revocable). Falls back to
# JWT_EXPIRES_IN then 30d. Default 30d.
JWT_REFRESH_EXPIRES_IN=30d
# PROD ONLY: parent domain so auth cookies are shared across the FE and API
# subdomains (e.g. .aifirst.us.com covers aifirst.us.com + api.aifirst.us.com).
# Leave UNSET in local dev (host-only cookie on localhost). Required in prod for
# the admin "revalidate cache" button to authorize; everything else works without.
COOKIE_DOMAIN=
EMAIL_USER=
EMAIL_SERVICE=gmail
EMAIL_PASSWORD=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
YANDEX_CLIENT_ID=fe6bd0522c784f9ba904f31beb910fdf
YANDEX_CLIENT_SECRET=f797e912981740a492b9b21c0c60fb18
BACKEND_URL=http://localhost:7272
YANDEX_REDIRECT_URI=http://localhost:7272/api/auth/yandex/callback
FRONTEND_URL=http://localhost:3033

# DeepL API key for post-content translation (public read endpoints with
# ?lang=en). Free tier → https://api-free.deepl.com. UNSET = translation is a
# graceful no-op: en reads degrade to the original (ru) fields, never 500.
DEEPL_AUTH_KEY=

# Admin → bot control proxy. URL of the bot's localhost control server + the
# SAME secret configured on the bot's BOT_CONTROL_TOKEN. Separate from
# BOT_API_TOKEN (bot→blog). Unset = the /api/admin/bot/* routes return 503.
BOT_CONTROL_URL=http://127.0.0.1:8455
BOT_CONTROL_TOKEN=

# Bot → blog service token (ai-bot-tg publishes posts). When the Bearer token
# equals BOT_API_TOKEN, requireAuth authenticates the request as the admin user
# found by OWNER_EMAIL. Unset = the service-token path is disabled.
BOT_API_TOKEN=
OWNER_EMAIL=

# Auto-publish master switches for the news bot (autoPublishReleases / autoPublishNews
# flags). FIRST-RUN seed only: after the owner toggles them in the blog /dashboard/admin,
# the app_settings DB rows are the source of truth. Off by default — the bot reads these
# via GET /api/admin/settings and fails closed (no read → items divert to the owner's
# manual Telegram approval, nothing auto-publishes). Separate keys so releases and news
# can be paused independently. No NEXT_PUBLIC_ twin — these are bot-only, admin-only.
AUTO_PUBLISH_RELEASES_ENABLED=false
AUTO_PUBLISH_NEWS_ENABLED=false

# Dogs Teacher booking API (separate Postgres database on the same VDS in prod)
DOGS_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dogs_teacher
# Online-booking master switch (dogsBooking flag). Off by default so no personal
# data of new clients is collected until an RKN notice is filed (152-ФЗ). This is
# only the FIRST-RUN seed: after the owner toggles it in the dogs /admin, the
# app_settings DB row is the source of truth and this env no longer matters. No
# frontend twin var — the dogs frontend reads the flag from the public API, so
# there is no backend/frontend drift to keep in sync (unlike PD_COLLECTION).
DOGS_BOOKING_ENABLED=false
DOGS_ADMIN_PASSWORD=
DOGS_ADMIN_SESSION_SECRET=
DOGS_TELEGRAM_BOT_TOKEN=
DOGS_TELEGRAM_WEBHOOK_SECRET=
DOGS_OWNER_TELEGRAM_ID=
DOGS_SITE_URL=http://localhost:3040
# Bot "Контакты" reply. Set DOGS_CONTACT_TEXT to fully override; otherwise the
# bot builds a phone + address + landmark + Yandex Maps block from these:
DOGS_CONTACT_TEXT=
DOGS_CONTACT_PHONE=
DOGS_CONTACT_ADDRESS=
DOGS_CONTACT_LANDMARK=
DOGS_CONTACT_MAPS_LINK=
# Web Push (VAPID). Generate a key pair once with `npx web-push generate-vapid-keys`.
# Both keys must be set to enable browser push; unset = push is a silent no-op.
# The public key is exposed to clients; the private key stays server-side.
DOGS_VAPID_PUBLIC_KEY=
DOGS_VAPID_PRIVATE_KEY=
DOGS_VAPID_SUBJECT=mailto:admin@example.com
# Optional shared secret for the internal reminders trigger
# (/api/dogs/internal/reminders, hit by an external cron). Unset = open trigger
# (safe: the endpoint only re-checks due reminders, never re-sends).
DOGS_REMINDERS_SECRET=
